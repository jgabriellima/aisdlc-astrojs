# Cursor agent runtime (required for AI-SDLC pipeline runs)
CURSOR_API_KEY=cur_your_key_here

# Optional: override default Cursor model for orchestrator runs
# AI_SDLC_CURSOR_MODEL=composer-2

# Pin orchestrator runner (default: cursor)
AI_SDLC_RUNNER=cursor

# GitHub integration (issue tracker + source control)
# GH_TOKEN=ghp_your_token_here
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_REPOSITORY=jgabriellima/aisdlc-astrojs
# GITHUB_REPOSITORY_OWNER=jgabriellima

# Optional runner timeout (ISO 8601 duration or ms)
# AI_SDLC_RUNNER_TIMEOUT=PT30M
